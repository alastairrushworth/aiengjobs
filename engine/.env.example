# Copy to .env on the droplet (never commit). Loaded via systemd EnvironmentFile.

# OpenAI — on-the-fly classification + skill tagging (cheapest model)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano

# SQLite database location on the droplet
AIENGJOBS_DB=/var/lib/aiengjobs/aiengjobs.db

# Override where `export` writes the site snapshot (defaults to ../site/src/data/snapshot.json)
# SNAPSHOT_OUT=

# Stripe (Phase 2)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
