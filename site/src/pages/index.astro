---
import Base from "../layouts/Base.astro";
import JobCard from "../components/JobCard.astro";
import { url } from "../lib/url.ts";
import { roleType, salaryRank } from "../lib/format.ts";
import snapshot from "../data/snapshot.json";
import { CLUSTER_PAGES } from "../lib/clusters.ts";
import type { SiteSnapshot } from "@aiengjobs/shared";

const data = snapshot as unknown as SiteSnapshot;
const jobs = data.jobs.filter((j) => !j.isClosed);

// Home page surfaces the 50 best-paid roles. The ranking is invisible — cards
// look identical, they're just ordered by (normalized) salary, highest first.
const HOME_LIMIT = 50;
const topJobs = [...jobs]
  .sort((a, b) => salaryRank(b) - salaryRank(a))
  .slice(0, HOME_LIMIT);

// Country filter — derived from the roles actually shown, so every option in the
// dropdown matches at least one visible card. ISO codes get a readable name.
const countryNames = new Intl.DisplayNames(["en"], { type: "region" });
const countryCounts = new Map<string, number>();
for (const j of topJobs) {
  if (j.country) countryCounts.set(j.country, (countryCounts.get(j.country) ?? 0) + 1);
}
const countries = [...countryCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([code, count]) => ({
    code,
    label: countryNames.of(code) ?? code,
    count,
  }));

// Role-type filter — bucket every shown listing into a generic role family and
// order by frequency, keeping the catch-all "Other" pinned last.
const roleCounts = new Map<string, number>();
for (const j of topJobs) {
  const r = roleType(j);
  roleCounts.set(r, (roleCounts.get(r) ?? 0) + 1);
}
const roles = [...roleCounts.entries()]
  .sort((a, b) =>
    a[0] === "Other" ? 1 : b[0] === "Other" ? -1 : b[1] - a[1],
  )
  .map(([label, count]) => ({ label, count }));
---

<Base title="AI Engineering Jobs — RAG, agents, evals, inference">
  <section class="hero">
    <h1>The job board for AI engineers</h1>
    <p>
      RAG, agents, evals, inference — browse <span class="count">{jobs.length}</span>
      first-party roles. Salary-transparent. No ghost jobs.
    </p>
  </section>

  <nav class="browse">
    <span class="browse-label">Browse by stack:</span>
    {CLUSTER_PAGES.map((p) => <a href={url(`/${p.slug}`)}>{p.label}</a>)}
  </nav>

  <div class="filters">
    <input
      type="search"
      id="q"
      placeholder="Search title, company, skill…"
      aria-label="Search jobs"
    />
    <div class="toggles">
      <select id="role" aria-label="Role type">
        <option value="">Any role</option>
        {roles.map((r) => (
          <option value={r.label}>{r.label}</option>
        ))}
      </select>
      <select id="country" aria-label="Country">
        <option value="">Any country</option>
        {countries.map((c) => (
          <option value={c.code}>{c.label}</option>
        ))}
      </select>
      <select id="seniority" aria-label="Seniority">
        <option value="">Any level</option>
        <option value="mid">Mid</option>
        <option value="senior">Senior</option>
        <option value="staff">Staff</option>
        <option value="principal">Principal</option>
        <option value="lead">Lead</option>
      </select>
    </div>
  </div>

  <p class="results-meta"><span id="shown">{topJobs.length}</span> of {topJobs.length} roles</p>

  <div class="jobs" id="jobs">
    {topJobs.map((job) => <JobCard job={job} href={url(`/jobs/${job.slug}`)} />)}
  </div>
  <p class="empty" id="empty">No roles match these filters yet.</p>
</Base>

<script>
  const q = document.getElementById("q") as HTMLInputElement;
  const role = document.getElementById("role") as HTMLSelectElement;
  const country = document.getElementById("country") as HTMLSelectElement;
  const seniority = document.getElementById("seniority") as HTMLSelectElement;
  const cards = Array.from(document.querySelectorAll<HTMLElement>("#jobs .job-card"));
  const shown = document.getElementById("shown")!;
  const empty = document.getElementById("empty")!;

  function apply() {
    const text = (q.value || "").trim().toLowerCase();
    const rol = role.value;
    const cty = country.value;
    const sen = seniority.value;
    let n = 0;
    for (const card of cards) {
      const matchText = !text || (card.dataset.search || "").includes(text);
      const matchRol = !rol || card.dataset.role === rol;
      const matchCty = !cty || card.dataset.country === cty;
      const matchSen = !sen || card.dataset.seniority === sen;
      const ok = matchText && matchRol && matchCty && matchSen;
      card.style.display = ok ? "" : "none";
      if (ok) n++;
    }
    shown.textContent = String(n);
    empty.style.display = n === 0 ? "block" : "none";
  }

  q.addEventListener("input", apply);
  role.addEventListener("change", apply);
  country.addEventListener("change", apply);
  seniority.addEventListener("change", apply);
</script>
