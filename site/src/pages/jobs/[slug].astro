---
import Base from "../../layouts/Base.astro";
import { formatSalary, remoteLabel, seniorityLabel } from "../../lib/format.ts";
import { url } from "../../lib/url.ts";
import snapshot from "../../data/snapshot.json";
import type { SiteSnapshot, Job } from "@aiengjobs/shared";

export function getStaticPaths() {
  const data = snapshot as unknown as SiteSnapshot;
  return data.jobs
    .filter((j) => !j.isClosed)
    .map((job) => ({ params: { slug: job.slug }, props: { job } }));
}

const { job } = Astro.props as { job: Job };
const salary = formatSalary(job);

// Cap the skill wall; the long tail adds noise more than signal.
const MAX_SKILLS = 16;
const skills = job.skills.slice(0, MAX_SKILLS);
const moreSkills = job.skills.length - skills.length;

// Render the description as real paragraphs + bullet lists. The text carries
// newlines, with list items prefixed by a bullet/dash marker (see stripHtml).
const BULLET_RE = /^\s*(?:[•·▪◦‣*]|[-–—](?=\s))\s*/;
type Block = { type: "p"; text: string } | { type: "ul"; items: string[] };
const blocks: Block[] = [];
for (const line of (job.descriptionText ?? "").split("\n")) {
  const trimmed = line.trim();
  if (!trimmed) continue;
  if (BULLET_RE.test(trimmed)) {
    const item = trimmed.replace(BULLET_RE, "").trim();
    if (!item) continue;
    const last = blocks[blocks.length - 1];
    if (last && last.type === "ul") last.items.push(item);
    else blocks.push({ type: "ul", items: [item] });
  } else {
    blocks.push({ type: "p", text: trimmed });
  }
}

// JobPosting structured data (JSON-LD) for SEO/GEO — spec §8.
const jsonLd: Record<string, unknown> = {
  "@context": "https://schema.org/",
  "@type": "JobPosting",
  title: job.title,
  hiringOrganization: { "@type": "Organization", name: job.companyName },
  employmentType: "FULL_TIME",
  datePosted: job.postedAt ?? job.ingestedAt,
  directApply: false,
};
if (job.remoteType === "remote") jsonLd.jobLocationType = "TELECOMMUTE";
if (job.country)
  jsonLd.applicantLocationRequirements = { "@type": "Country", name: job.country };
if (job.salaryMin) {
  jsonLd.baseSalary = {
    "@type": "MonetaryAmount",
    currency: job.salaryCurrency ?? "USD",
    value: {
      "@type": "QuantitativeValue",
      minValue: job.salaryMin,
      maxValue: job.salaryMax ?? job.salaryMin,
      unitText: "YEAR",
    },
  };
}
---

<Base
  title={`${job.title} · ${job.companyName}`}
  description={`${job.title} at ${job.companyName}. ${salary ?? "AI engineering role."}`}
>
  <article class="job-detail">
    <p><a class="back" href={url("/")}>← All jobs</a></p>
    <h1>{job.title}</h1>
    <p class="company">
      <a href={url(`/companies/${job.companySlug}`)} style="color:var(--accent)">{job.companyName}</a>{job.locationRaw ? ` · ${job.locationRaw}` : ""}
    </p>
    <div class="meta">
      {salary && <span class="badge new">{salary}</span>}
      {remoteLabel(job.remoteType) && <span class="badge">{remoteLabel(job.remoteType)}</span>}
      {seniorityLabel(job.seniority) && <span class="badge">{seniorityLabel(job.seniority)}</span>}
    </div>
    {skills.length > 0 && (
      <div class="meta skills">
        {skills.map((s) => <span class="badge skill">{s}</span>)}
        {moreSkills > 0 && <span class="badge more">+{moreSkills} more</span>}
      </div>
    )}
    {blocks.length > 0 && (
      <div class="desc">
        {blocks.map((b) =>
          b.type === "ul" ? (
            <ul>{b.items.map((it) => <li>{it}</li>)}</ul>
          ) : (
            <p>{b.text}</p>
          ),
        )}
      </div>
    )}
    <p class="apply-wrap">
      <a class="apply" href={job.applyUrl} target="_blank" rel="noopener nofollow">
        Apply on company site →
      </a>
    </p>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
</Base>

<style>
  .job-detail { max-width: 720px; padding: 32px 0; }
  .job-detail h1 { font-size: 1.8rem; letter-spacing: -0.02em; margin: 12px 0 6px; }
  .job-detail .company { color: var(--muted); margin: 0 0 16px; }
  .job-detail .meta { display: flex; flex-wrap: wrap; gap: 8px; }
  .job-detail .skills { margin-top: 12px; }
  .badge.more { color: var(--muted); }
  .back { color: var(--muted); }
  .desc { margin-top: 28px; color: var(--text); line-height: 1.7; }
  .desc p { margin: 0 0 14px; }
  .desc ul { margin: 0 0 14px; padding-left: 1.25rem; }
  .desc li { margin: 0 0 6px; }
  .desc li:last-child { margin-bottom: 0; }
  .desc > :last-child { margin-bottom: 0; }
  .apply-wrap { margin-top: 28px; }
  .apply {
    display: inline-block;
    background: var(--accent);
    color: #fff;
    padding: 12px 20px;
    border-radius: 10px;
    font-weight: 600;
  }
  .apply:hover { filter: brightness(1.08); }
</style>
