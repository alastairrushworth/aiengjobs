---
import Base from "../../layouts/Base.astro";
import { url } from "../../lib/url.ts";
import { formatSalary } from "../../lib/format.ts";
import snapshot from "../../data/snapshot.json";
import { CLUSTER_PAGES } from "../../lib/clusters.ts";
import type { SiteSnapshot, Job } from "@aiengjobs/shared";
import type { ClusterPage } from "../../lib/clusters.ts";

export function getStaticPaths() {
  const data = snapshot as unknown as SiteSnapshot;
  const open = data.jobs.filter((j) => !j.isClosed);
  return CLUSTER_PAGES.map((page) => {
    const salaried = open.filter(
      (j) =>
        j.clusters.includes(page.id) &&
        j.salaryMin &&
        (!j.salaryCurrency || j.salaryCurrency === "USD") &&
        (!j.salaryPeriod || j.salaryPeriod === "year"),
    );
    return { params: { cluster: page.id }, props: { page, salaried } };
  });
}

const { page, salaried } = Astro.props as { page: ClusterPage; salaried: Job[] };

const mids = salaried
  .map((j) => (j.salaryMax ? (j.salaryMin! + j.salaryMax) / 2 : j.salaryMin!))
  .sort((a, b) => a - b);

function median(xs: number[]): number {
  if (xs.length === 0) return 0;
  const m = Math.floor(xs.length / 2);
  return xs.length % 2 ? xs[m] : (xs[m - 1] + xs[m]) / 2;
}
const k = (n: number) => `$${Math.round(n / 1000)}k`;

const stats =
  mids.length > 0
    ? { count: mids.length, min: mids[0], median: median(mids), max: mids[mids.length - 1] }
    : null;

const roleNoun = page.label.replace(/ \/.*/, "");
const jsonLd = stats
  ? {
      "@context": "https://schema.org",
      "@type": "Occupation",
      name: `${roleNoun} (AI engineering)`,
      estimatedSalary: {
        "@type": "MonetaryAmountDistribution",
        currency: "USD",
        duration: "P1Y",
        median: Math.round(stats.median),
        percentile10: Math.round(stats.min),
        percentile90: Math.round(stats.max),
      },
    }
  : null;
---

<Base
  title={`${roleNoun} salaries — AI engineering pay data — aiengjobs`}
  description={
    stats
      ? `${roleNoun} salaries from ${stats.count} live roles: median ${k(stats.median)}, range ${k(stats.min)}–${k(stats.max)} (USD/yr).`
      : `${roleNoun} salary data from live AI-engineering roles.`
  }
>
  <section class="hero" style="padding-bottom:8px">
    <h1>{roleNoun} salaries</h1>
    <p>
      Live salary data from first-party {page.label} postings (USD/yr).
      No surveys — pay ranges employers actually publish.
    </p>
  </section>

  {stats ? (
    <>
      <div class="salary-stats">
        <div><span class="num">{k(stats.median)}</span><span class="lbl">median</span></div>
        <div><span class="num">{k(stats.min)}</span><span class="lbl">low</span></div>
        <div><span class="num">{k(stats.max)}</span><span class="lbl">high</span></div>
        <div><span class="num">{stats.count}</span><span class="lbl">data points</span></div>
      </div>

      <h2 style="margin-top:28px;font-size:1.1rem">Roles with published pay</h2>
      <div class="jobs">
        {salaried.map((j) => (
          <a class="job-card" href={url(`/jobs/${j.slug}`)}>
            <div class="top">
              <div>
                <h3>{j.title}</h3>
                <div class="company">{j.companyName}{j.locationRaw ? ` · ${j.locationRaw}` : ""}</div>
              </div>
              <div class="salary">{formatSalary(j)}</div>
            </div>
          </a>
        ))}
      </div>
    </>
  ) : (
    <p style="text-align:center;color:var(--muted);padding:32px 0">
      No published salary data for {page.label} roles yet — check back as more roles are ingested.
    </p>
  )}

  <nav class="browse" style="margin-top:40px">
    <span style="color:var(--muted);font-size:.85rem">More:</span>
    <a href={url(`/${page.slug}`)}>All {page.label} jobs →</a>
    {CLUSTER_PAGES.filter((p) => p.id !== page.id).map((p) => (
      <a href={url(`/salaries/${p.id}`)}>{p.label} pay</a>
    ))}
  </nav>

  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />}
</Base>
